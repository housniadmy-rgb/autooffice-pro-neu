{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "praxisonline24/ai/hub/knowledge-base/schema.json",
  "title": "Knowledge Base Entry",
  "description": "Ein Eintrag in der Wissensbasis: Problem, Lösung, Best Practice oder Anti-Pattern.",
  "type": "object",
  "required": ["id", "kind", "title", "summary", "status", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^kb_[a-z0-9_-]+$"
    },
    "kind": {
      "type": "string",
      "enum": ["problem", "solution", "best_practice", "anti_pattern"]
    },
    "title": { "type": "string", "minLength": 3, "maxLength": 200 },
    "summary": { "type": "string", "minLength": 3, "maxLength": 1000 },
    "details": { "type": "string", "maxLength": 8000 },
    "status": {
      "type": "string",
      "enum": ["draft", "validated", "archived"],
      "default": "draft"
    },
    "owner": {
      "type": "string",
      "enum": [
        "ceo",
        "cto",
        "qa",
        "seo",
        "marketing",
        "sales",
        "support",
        "finance",
        "security",
        "monitoring",
        "operations"
      ]
    },
    "related_event_types": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "default": []
    },
    "related_entries": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "default": []
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "default": []
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "url": { "type": ["string", "null"], "format": "uri" }
        }
      },
      "default": []
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
