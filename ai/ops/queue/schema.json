{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "praxisonline24/ai/ops/queue/schema.json",
  "title": "Operations Queue Entry",
  "description": "Ein Eintrag in der Operations Queue. Repräsentiert einen verteilbaren Task. Ausführung erfolgt in Phase 9 ausschließlich als Dry-Run.",
  "type": "object",
  "required": [
    "queue_id",
    "task_id",
    "owner",
    "state",
    "enqueued_at"
  ],
  "additionalProperties": false,
  "properties": {
    "queue_id": {
      "type": "string",
      "pattern": "^q_[a-z0-9_-]+_[0-9]+$"
    },
    "task_id": {
      "type": "string",
      "description": "Verweis auf ai/engine/tasks (Task.id)."
    },
    "owner": {
      "type": "string",
      "enum": [
        "ceo",
        "cto",
        "qa",
        "seo",
        "marketing",
        "sales",
        "support",
        "finance",
        "security",
        "monitoring",
        "operations"
      ]
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "info"],
      "default": "info"
    },
    "state": {
      "type": "string",
      "enum": [
        "queued",
        "assigned",
        "awaiting_approval",
        "ready_for_execution",
        "dry_running",
        "completed",
        "rejected",
        "failed",
        "cancelled"
      ]
    },
    "policy_class": {
      "type": ["string", "null"],
      "enum": ["safe", "critical", null]
    },
    "approval_id": { "type": ["string", "null"] },
    "execution_id": { "type": ["string", "null"] },
    "slot": {
      "type": ["string", "null"],
      "description": "Slot-Kennung der Abteilung, z. B. 'seo:1'."
    },
    "attempts": { "type": "integer", "minimum": 0, "default": 0 },
    "max_attempts": { "type": "integer", "minimum": 1, "default": 3 },
    "enqueued_at": { "type": "string", "format": "date-time" },
    "assigned_at": { "type": ["string", "null"], "format": "date-time" },
    "completed_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
