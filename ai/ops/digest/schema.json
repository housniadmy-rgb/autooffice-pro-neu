{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "praxisonline24/ai/ops/digest/schema.json",
  "title": "CEO Daily Digest",
  "description": "Read-only Tageszusammenfassung für den CEO.",
  "type": "object",
  "required": ["digest_id", "date", "generated_at", "headline", "sections"],
  "additionalProperties": false,
  "properties": {
    "digest_id": {
      "type": "string",
      "pattern": "^dig_[0-9]{4}-[0-9]{2}-[0-9]{2}_[a-z0-9_-]+$"
    },
    "date": { "type": "string", "format": "date" },
    "generated_at": { "type": "string", "format": "date-time" },
    "headline": { "type": "string", "minLength": 3, "maxLength": 280 },
    "health": {
      "type": "object",
      "required": ["score", "tier"],
      "additionalProperties": false,
      "properties": {
        "snapshot_id": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "tier": {
          "type": "string",
          "enum": ["healthy", "watch", "degraded", "critical"]
        }
      }
    },
    "sections": {
      "type": "object",
      "additionalProperties": false,
      "required": ["queue", "executions", "approvals", "highlights"],
      "properties": {
        "queue": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "awaiting_approval": { "type": "integer", "minimum": 0 },
            "ready_for_execution": { "type": "integer", "minimum": 0 },
            "by_owner": {
              "type": "object",
              "additionalProperties": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "executions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "started": { "type": "integer", "minimum": 0 },
            "completed": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 },
            "rejected": { "type": "integer", "minimum": 0 },
            "dry_run_only": { "type": "boolean", "const": true }
          }
        },
        "approvals": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "pending_total": { "type": "integer", "minimum": 0 },
            "pending_critical": { "type": "integer", "minimum": 0 },
            "pending_ids": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            }
          }
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["headline"],
            "additionalProperties": false,
            "properties": {
              "headline": { "type": "string", "maxLength": 200 },
              "feed_id": { "type": ["string", "null"] },
              "severity": {
                "type": "string",
                "enum": ["critical", "high", "medium", "low", "info"]
              }
            }
          },
          "default": []
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text"],
        "additionalProperties": false,
        "properties": {
          "text": { "type": "string", "maxLength": 1000 },
          "requires_human_decision": { "type": "boolean", "const": true }
        }
      },
      "default": []
    }
  }
}
