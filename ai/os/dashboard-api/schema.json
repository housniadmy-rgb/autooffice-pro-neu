{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ai/os/dashboard-api/schema.json",
  "title": "DashboardView",
  "description": "Spezifikation einer read-only Aggregations-View.",
  "type": "object",
  "required": ["id", "sources", "fields"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^view_[a-z0-9]+(_[a-z0-9]+)*$"
    },
    "description": { "type": "string" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "description": "Relativer Modul-Pfad als Quelle, z. B. ai/ops/digest." }
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["string", "number", "integer", "boolean", "datetime", "array", "object", "enum"] },
          "from": { "type": "string", "description": "JSON-Pointer auf das Feld in der Quelle." },
          "enum": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "default_sort": {
      "type": "object",
      "properties": {
        "field": { "type": "string" },
        "direction": { "type": "string", "enum": ["asc", "desc"], "default": "desc" }
      },
      "additionalProperties": false
    },
    "page_size_default": { "type": "integer", "default": 50, "minimum": 1, "maximum": 200 },
    "cache_seconds": { "type": "integer", "default": 60, "minimum": 0 },
    "permission_required": { "type": "string", "pattern": "^read:[a-z_]+(:[a-z_]+)?$" },
    "visibility": { "type": "string", "enum": ["internal", "external"], "default": "internal" }
  },
  "additionalProperties": false
}
