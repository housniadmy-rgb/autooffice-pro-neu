{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ai/os/api-gateway/schema.json",
  "title": "GatewayEndpoint",
  "description": "Spezifikation eines externen Endpunkts. In Phase 11 ausnahmslos deaktiviert.",
  "type": "object",
  "required": ["id", "path", "method", "binds_to", "enabled"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^endpoint_[a-z0-9]+(_[a-z0-9]+)*$"
    },
    "description": { "type": "string" },
    "path": {
      "type": "string",
      "pattern": "^/api/v1/[a-z0-9/_:-]+$"
    },
    "method": {
      "type": "string",
      "enum": ["GET", "HEAD"]
    },
    "binds_to": {
      "type": "string",
      "description": "ID einer Dashboard-API-View oder eines anderen read-only Modells.",
      "pattern": "^view_[a-z0-9]+(_[a-z0-9]+)*$"
    },
    "permission_required": {
      "type": "string",
      "pattern": "^read:[a-z_]+(:[a-z_]+)?$"
    },
    "rate_limit_per_minute": { "type": "integer", "default": 30, "minimum": 1 },
    "auth_required": { "type": "boolean", "default": true },
    "visibility": { "type": "string", "enum": ["internal", "external"], "default": "external" },
    "enabled": {
      "type": "boolean",
      "default": false,
      "description": "Pflicht-Flag. In Phase 11 immer false."
    }
  },
  "additionalProperties": false
}
