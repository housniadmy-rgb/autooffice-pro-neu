{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "praxisonline24/ai/engine/workflows/schema.json",
  "title": "Workflow",
  "description": "Geordnete Verkettung von Tasks über mehrere AI-Abteilungen hinweg. In dieser Phase ausschließlich deklarativ.",
  "type": "object",
  "required": ["id", "name", "trigger", "steps", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^wf_[a-z0-9_-]+$"
    },
    "name": { "type": "string", "minLength": 3, "maxLength": 120 },
    "description": { "type": "string", "maxLength": 2000 },
    "trigger": {
      "type": "string",
      "enum": ["manual"],
      "description": "In Phase 7 ist ausschließlich manuelle Auslösung erlaubt."
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "global_requires_approval": { "type": "boolean", "default": true },
        "stop_on_failure": { "type": "boolean", "default": true },
        "max_parallel": { "type": "integer", "minimum": 1, "default": 1 }
      },
      "default": {}
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_id", "owner", "title"],
        "additionalProperties": false,
        "properties": {
          "step_id": { "type": "string", "pattern": "^s_[a-z0-9_-]+$" },
          "owner": {
            "type": "string",
            "enum": [
              "ceo",
              "cto",
              "qa",
              "seo",
              "marketing",
              "sales",
              "support",
              "finance",
              "security",
              "monitoring",
              "operations"
            ]
          },
          "title": { "type": "string", "minLength": 3, "maxLength": 200 },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true,
            "default": []
          },
          "mode": {
            "type": "string",
            "enum": ["sequential", "parallel", "fan_in"],
            "default": "sequential"
          },
          "task_template": {
            "type": "object",
            "additionalProperties": true,
            "description": "Skelett für vom Workflow erzeugte Tasks."
          },
          "requires_approval": { "type": "boolean", "default": true }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
