# ============================================================
# PraxisOnline24 – Umgebungsvariablen (Konfigurationsvorlage)
# Kopieren Sie diese Datei zu .env.local und füllen Sie die
# Werte mit Ihren eigenen Zugangsdaten.
# ============================================================

# Supabase (https://app.supabase.com → Projekt → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://IHRE-PROJEKT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=IHR_SUPABASE_ANON_KEY

# Stripe Checkout-Links (https://dashboard.stripe.com → Payment Links)
NEXT_PUBLIC_STRIPE_BASIC_LINK=https://buy.stripe.com/IHR_BASIC_LINK
NEXT_PUBLIC_STRIPE_PRO_LINK=https://buy.stripe.com/IHR_PRO_LINK
NEXT_PUBLIC_STRIPE_BUSINESS_LINK=https://buy.stripe.com/IHR_BUSINESS_LINK

# Stripe Secret Key (nur serverseitig, nicht im Browser!)
# Format: sk_live_... oder sk_test_... – aus Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=IHR_STRIPE_SECRET_KEY

# Google Maps API Key (optional, für Arzt-Karte)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXX
