# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Session ───────────────────────────────────────────────────
# Mindestens 32 zufällige Zeichen – niemals den Beispielwert verwenden!
# Generator: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-use-a-long-random-string-in-production

# ── E-Mail (Brevo Transactional API) ──────────────────────────
# Bei EMAIL_DEV_MODE=true werden keine E-Mails versendet (nur Konsole).
# Wenn BREVO_API_KEY fehlt, läuft alles als DEV-Log weiter (kein Versand).
EMAIL_DEV_MODE=false
BREVO_API_KEY=xkeysib-...

# Absender-Adresse für alle Mails. Format "Name <addr@domain>" oder reine Adresse.
# Hinweis: Bei Brevo muss die Absender-Domain im Brevo-Dashboard verifiziert sein.
SMTP_FROM=PraxisOnline24 <info@praxisonline24.com>

# Empfänger für CEO-Reports, Owner-Benachrichtigungen und kritische System-Mails
OWNER_EMAIL=info@praxisonline24.com

# Basis-URL für Links in E-Mails (Passwort-Reset, Einladungen, Termin-Bestätigungen)
# Lokal: http://localhost:3000 · Produktion: https://praxisonline24.com
APP_URL=http://localhost:3000

# Legacy-SMTP-Variablen werden NICHT mehr verwendet – Versand läuft über
# api.brevo.com/v3/smtp/email per HTTPS. SMTP_HOST/PORT/USER/PASS können
# in der Render-Env gelöscht werden.
